<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0A0A0F" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="SpendLog" />
  <meta name="application-name" content="SpendLog" />
  <meta name="description" content="SpendLog — personal spending dashboard" />
  <meta name="msapplication-TileColor" content="#0A0A0F" />
  <!-- Force fresh load — prevents stale SW cache from serving old file -->
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%230A0A0F'/%3E%3Crect x='8' y='16' width='48' height='32' rx='6' fill='none' stroke='%23F0A500' stroke-width='4'/%3E%3Cpath d='M8 26h48' stroke='%23F0A500' stroke-width='3'/%3E%3Ccircle cx='18' cy='38' r='3' fill='%23F0A500'/%3E%3Ccircle cx='28' cy='38' r='3' fill='%23F0A500'/%3E%3C/svg%3E" />
  <!-- SW KILLER: must be first script, runs before any render -->
  <script>
    (function() {
      if (!('serviceWorker' in navigator)) return;
      // Already did the clean reload — don't loop
      if (location.search.indexOf('swcleared') !== -1) return;
      navigator.serviceWorker.getRegistrations().then(function(regs) {
        if (!regs.length) return;
        Promise.all(regs.map(function(r) { return r.unregister(); })).then(function() {
          // Clear ALL caches too
          if ('caches' in window) {
            caches.keys().then(function(keys) {
              return Promise.all(keys.map(function(k) { return caches.delete(k); }));
            }).then(function() {
              // Reload with marker so we don't loop
              var sep = location.search ? '&' : '?';
              location.replace(location.href.split('?')[0] + '?swcleared=1');
            });
          } else {
            location.replace(location.href.split('?')[0] + '?swcleared=1');
          }
        });
      });
    })();
  </script>
  <title>SpendLog — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0A0A0F;
      --surface: #111118;
      --surface2: #18181F;
      --border: rgba(255,255,255,0.06);
      --accent: #F0A500;
      --accent2: #FF6B35;
      --text: #F0F0FF;
      --muted: #606080;
      --danger: #FF4060;
      --success: #00D4A0;
      --mono: 'Space Mono', monospace;
      --sans: 'Syne', sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--sans); -webkit-font-smoothing: antialiased; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; color: inherit; }
    input { font-family: inherit; }

    #lock {
      position: fixed; inset: 0; z-index: 1000;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      background: var(--bg);
      background-image: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(240,165,0,0.08) 0%, transparent 100%);
    }
    .lock-logo { width: 64px; height: 64px; border-radius: 18px; background: var(--accent); display: flex; align-items: center; justify-content: center; margin-bottom: 32px; box-shadow: 0 0 60px rgba(240,165,0,0.3); animation: pulse 3s ease-in-out infinite; }
    .lock-logo svg { width: 32px; height: 32px; }
    .lock-title { font-size: 2rem; font-weight: 800; letter-spacing: -0.04em; margin-bottom: 8px; }
    .lock-sub { font-size: 0.85rem; color: var(--muted); margin-bottom: 40px; font-family: var(--mono); }
    .lock-form { display: flex; flex-direction: column; gap: 12px; width: 320px; }
    .lock-input { width: 100%; padding: 14px 18px; background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; color: var(--text); font-size: 1rem; font-family: var(--mono); outline: none; letter-spacing: 0.1em; transition: border-color 0.2s; }
    .lock-input:focus { border-color: var(--accent); }
    .lock-input.error { border-color: var(--danger); animation: shake 0.4s ease; }
    .lock-btn { padding: 14px; background: var(--accent); color: #000; font-weight: 700; font-size: 0.95rem; border-radius: 10px; letter-spacing: 0.05em; font-family: var(--sans); transition: transform 0.15s, box-shadow 0.15s; }
    .lock-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 30px rgba(240,165,0,0.3); }
    .lock-error { font-size: 0.8rem; color: var(--danger); text-align: center; font-family: var(--mono); height: 20px; }
    #lock.hidden { display: none; }

    #dash { display: none; min-height: 100vh; }
    #dash.visible { display: block; }

    .sidebar { position: fixed; top: 0; left: 0; bottom: 0; width: 220px; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; padding: 24px 16px; z-index: 10; }
    .sidebar-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 36px; padding: 0 8px; }
    .sidebar-logo-icon { width: 32px; height: 32px; background: var(--accent); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sidebar-logo-icon svg { width: 16px; height: 16px; }
    .sidebar-logo-text { font-size: 1.1rem; font-weight: 800; letter-spacing: -0.03em; }
    .sidebar-badge { font-size: 0.55rem; font-family: var(--mono); background: var(--accent); color: #000; padding: 1px 5px; border-radius: 3px; font-weight: 700; display: block; margin-top: 2px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; margin-bottom: 2px; font-size: 0.875rem; font-weight: 600; color: var(--muted); cursor: pointer; transition: all 0.15s; }
    .nav-item:hover { background: var(--surface2); color: var(--text); }
    .nav-item.active { background: rgba(240,165,0,0.1); color: var(--accent); }
    .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }
    .sidebar-bottom { margin-top: auto; }
    .sidebar-device { padding: 10px 12px; background: var(--surface2); border-radius: 8px; font-size: 0.7rem; font-family: var(--mono); color: var(--muted); word-break: break-all; }
    .sidebar-device-label { color: var(--accent); font-size: 0.6rem; margin-bottom: 4px; }
    .lock-out-btn { display: flex; align-items: center; gap: 8px; width: 100%; padding: 10px 12px; margin-top: 8px; border-radius: 8px; font-size: 0.875rem; font-weight: 600; color: var(--danger); transition: background 0.15s; }
    .lock-out-btn:hover { background: rgba(255,64,96,0.1); }

    .main { margin-left: 220px; padding: 32px; min-height: 100vh; }
    .page { display: none; }
    .page.active { display: block; animation: fadeIn 0.3s ease; }
    .page-header { margin-bottom: 28px; }
    .page-title { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.04em; }
    .page-sub { font-size: 0.85rem; color: var(--muted); margin-top: 4px; font-family: var(--mono); }

    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
    @media (max-width: 1200px) { .stats-grid { grid-template-columns: repeat(2,1fr); } }
    .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 20px; position: relative; overflow: hidden; }
    .stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--accent), var(--accent2)); }
    .stat-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
    .stat-value { font-family: var(--mono); font-size: 1.8rem; font-weight: 700; }
    .stat-change { font-size: 0.75rem; color: var(--muted); margin-top: 6px; font-family: var(--mono); }

    .two-col { display: grid; grid-template-columns: 1fr 360px; gap: 16px; }
    @media (max-width: 1100px) { .two-col { grid-template-columns: 1fr; } }
    .panel { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 20px; }
    .panel-title { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }

    .cal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .cal-month-label { font-size: 1rem; font-weight: 700; }
    .cal-nav { display: flex; gap: 8px; }
    .cal-nav-btn { width: 30px; height: 30px; background: var(--surface2); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 14px; color: var(--muted); transition: color 0.15s, background 0.15s; }
    .cal-nav-btn:hover { background: rgba(255,255,255,0.08); color: var(--text); }
    .cal-weekdays { display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; margin-bottom: 4px; }
    .cal-weekday { text-align: center; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); padding: 3px 0; }
    .cal-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; }
    .cal-cell { aspect-ratio: 1; border-radius: 7px; background: var(--surface2); display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; transition: transform 0.1s; padding: 2px; }
    .cal-cell:hover:not(.empty) { transform: scale(1.08); }
    .cal-cell.empty { background: transparent; cursor: default; pointer-events: none; }
    .cal-cell.today { box-shadow: inset 0 0 0 1.5px var(--accent); }
    .cal-cell.selected { background: rgba(240,165,0,0.2) !important; }
    .cal-cell.spend-low  { background: rgba(240,165,0,0.12); }
    .cal-cell.spend-mid  { background: rgba(240,165,0,0.32); }
    .cal-cell.spend-high { background: rgba(240,165,0,0.58); }
    .cal-day { font-family: var(--mono); font-size: 0.62rem; font-weight: 700; color: var(--muted); line-height: 1; }
    .cal-cell.spend-low .cal-day, .cal-cell.spend-mid .cal-day { color: var(--accent); }
    .cal-cell.spend-high .cal-day { color: #000; }
    .cal-cell.today .cal-day { color: var(--accent); }
    .cal-amt { font-family: var(--mono); font-size: 0.42rem; color: var(--accent); margin-top: 1px; }
    .cal-cell.spend-high .cal-amt { color: #000; }

    .txn-list { display: flex; flex-direction: column; gap: 2px; max-height: 440px; overflow-y: auto; }
    .txn-row { display: flex; align-items: center; gap: 12px; padding: 9px 10px; border-radius: 8px; cursor: pointer; transition: background 0.1s; }
    .txn-row:hover { background: var(--surface2); }
    .txn-icon { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
    .txn-info { flex: 1; min-width: 0; }
    .txn-name { font-size: 0.83rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .txn-date { font-size: 0.68rem; color: var(--muted); font-family: var(--mono); margin-top: 1px; }
    .txn-amt { font-family: var(--mono); font-size: 0.88rem; font-weight: 700; white-space: nowrap; }
    .badge { font-size: 0.58rem; padding: 1px 5px; border-radius: 4px; font-weight: 700; margin-left: 4px; }
    .badge-pending { background: rgba(240,165,0,0.15); color: var(--accent); }
    .badge-apple { background: rgba(255,255,255,0.06); color: var(--muted); }

    .day-panel-date { font-size: 0.95rem; font-weight: 700; margin-bottom: 4px; }
    .day-panel-total { font-family: var(--mono); font-size: 1.5rem; font-weight: 700; color: var(--accent); }
    .day-panel-count { font-size: 0.72rem; color: var(--muted); font-family: var(--mono); margin-top: 2px; margin-bottom: 14px; }
    .day-txns { display: flex; flex-direction: column; gap: 2px; max-height: 360px; overflow-y: auto; }

    .accounts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .account-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 20px; display: flex; align-items: center; gap: 14px; }
    .account-icon { width: 46px; height: 46px; border-radius: 12px; background: rgba(240,165,0,0.1); display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .account-name { font-weight: 700; font-size: 0.9rem; }
    .account-meta { font-size: 0.75rem; color: var(--muted); margin-top: 3px; }
    .connect-card { background: var(--surface); border: 2px dashed rgba(240,165,0,0.25); border-radius: 14px; padding: 24px; display: flex; flex-direction: column; align-items: center; gap: 10px; cursor: pointer; transition: border-color 0.2s, background 0.2s; text-align: center; }
    .connect-card:hover { border-color: var(--accent); background: rgba(240,165,0,0.04); }
    .connect-card-title { font-weight: 700; color: var(--accent); }
    .connect-card-sub { font-size: 0.78rem; color: var(--muted); }

    .spinner { width: 28px; height: 28px; border: 2px solid var(--surface2); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 28px auto; }
    .empty-state { text-align: center; padding: 32px 20px; color: var(--muted); font-size: 0.83rem; font-family: var(--mono); }

    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes pulse { 0%,100% { box-shadow: 0 0 40px rgba(240,165,0,0.2); } 50% { box-shadow: 0 0 80px rgba(240,165,0,0.5); } }
    @keyframes shake { 0%,100% { transform: translateX(0); } 25% { transform: translateX(-8px); } 75% { transform: translateX(8px); } }
    @keyframes fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }

    /* Native app: safe-area insets for notch/home-bar on iOS & Android */
    @media (display-mode: standalone) {
      .sidebar { padding-top: calc(24px + env(safe-area-inset-top)) !important; }
      .main    { padding-top: calc(32px + env(safe-area-inset-top)); }
      #lock    { padding-top: env(safe-area-inset-top); }
    }
    body.ios-standalone .sidebar { padding-top: calc(24px + env(safe-area-inset-top)) !important; }
    body.ios-standalone .main    { padding-top: calc(32px + env(safe-area-inset-top)); }
    body.ios-standalone #lock    { padding-top: env(safe-area-inset-top); }

    /* Native app: kill 300ms tap delay */
    button, a, [onclick] { touch-action: manipulation; }

    /* Install banner slide-up animation */
    @keyframes sl-slideUp { from { transform:translateY(20px);opacity:0 } to { transform:translateY(0);opacity:1 } }
    ::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-track { background: transparent; } ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  </style>
</head>
<body>

<div id="lock">
  <div class="lock-logo">
    <svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5">
      <rect x="2" y="5" width="20" height="16" rx="3"/>
      <path d="M16 3v4M8 3v4M2 11h20"/>
      <circle cx="8" cy="16" r="1.5" fill="#000"/>
      <circle cx="12" cy="16" r="1.5" fill="#000"/>
      <circle cx="16" cy="16" r="1.5" fill="#000"/>
    </svg>
  </div>
  <div class="lock-title">SpendLog</div>
  <div class="lock-sub">// ADMIN ACCESS ONLY</div>
  <div class="lock-form">
    <input class="lock-input" id="key-input" type="password" placeholder="Enter admin key" autocomplete="off" />
    <button class="lock-btn" onclick="tryUnlock()">UNLOCK DASHBOARD</button>
    <div class="lock-error" id="lock-error"></div>
  </div>
</div>

<div id="dash">
  <div class="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5"><rect x="2" y="5" width="20" height="16" rx="3"/><path d="M16 3v4M8 3v4M2 11h20"/></svg>
      </div>
      <div>
        <div class="sidebar-logo-text">SpendLog</div>
        <span class="sidebar-badge">ADMIN</span>
      </div>
    </div>

    <div class="nav-item active" data-page="overview" onclick="showPage(this,'overview')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Overview
    </div>
    <div class="nav-item" data-page="calendar" onclick="showPage(this,'calendar')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      Calendar
    </div>
    <div class="nav-item" data-page="transactions" onclick="showPage(this,'transactions')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>
      Transactions
    </div>
    <div class="nav-item" data-page="accounts" onclick="showPage(this,'accounts')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M3 10h18M3 7l9-4 9 4M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/></svg>
      Banks
    </div>

    <div class="sidebar-bottom">
      <div class="sidebar-device">
        <div class="sidebar-device-label">DEVICE ID</div>
        <span id="device-id-display">—</span>
      </div>
      <button class="lock-out-btn" onclick="lockOut()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Lock Dashboard
      </button>
    </div>
  </div>

  <div class="main">
    <div class="page active" id="page-overview">
      <div class="page-header">
        <div class="page-title">Overview</div>
        <div class="page-sub" id="overview-date">—</div>
      </div>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-label">This Month</div><div class="stat-value" id="stat-month">—</div><div class="stat-change" id="stat-txn-count">—</div></div>
        <div class="stat-card"><div class="stat-label">Today</div><div class="stat-value" id="stat-today">—</div><div class="stat-change" id="stat-today-count">—</div></div>
        <div class="stat-card"><div class="stat-label">Connected Banks</div><div class="stat-value" id="stat-banks">—</div><div class="stat-change">active accounts</div></div>
        <div class="stat-card"><div class="stat-label">Last Transaction</div><div class="stat-value" id="stat-last-amt">—</div><div class="stat-change" id="stat-last-name">—</div></div>
      </div>
      <div class="two-col">
        <div class="panel">
          <div class="panel-title">Recent Transactions</div>
          <div class="txn-list" id="recent-txns"><div class="spinner"></div></div>
        </div>
        <div class="panel">
          <div class="panel-title">This Month</div>
          <div class="cal-weekdays">
            <div class="cal-weekday">Su</div><div class="cal-weekday">Mo</div><div class="cal-weekday">Tu</div>
            <div class="cal-weekday">We</div><div class="cal-weekday">Th</div><div class="cal-weekday">Fr</div><div class="cal-weekday">Sa</div>
          </div>
          <div class="cal-grid" id="mini-cal"><div class="spinner"></div></div>
        </div>
      </div>
    </div>

    <div class="page" id="page-calendar">
      <div class="page-header">
        <div class="page-title">Spending Calendar</div>
        <div class="page-sub">Click any day to see transactions</div>
      </div>
      <div class="two-col">
        <div class="panel">
          <div class="cal-header">
            <span class="cal-month-label" id="full-month-label">—</span>
            <div style="display:flex;align-items:center;gap:16px">
              <span style="font-family:var(--mono);font-size:.85rem;color:var(--accent)" id="full-month-total">—</span>
              <div class="cal-nav">
                <button class="cal-nav-btn" onclick="calPrev()">‹</button>
                <button class="cal-nav-btn" onclick="calNext()">›</button>
              </div>
            </div>
          </div>
          <div class="cal-weekdays">
            <div class="cal-weekday">Su</div><div class="cal-weekday">Mo</div><div class="cal-weekday">Tu</div>
            <div class="cal-weekday">We</div><div class="cal-weekday">Th</div><div class="cal-weekday">Fr</div><div class="cal-weekday">Sa</div>
          </div>
          <div class="cal-grid" id="full-cal"><div class="spinner"></div></div>
        </div>
        <div class="panel">
          <div class="day-panel-date" id="day-panel-date" style="color:var(--muted)">Select a day</div>
          <div class="day-panel-total" id="day-panel-total"></div>
          <div class="day-panel-count" id="day-panel-count"></div>
          <div class="day-txns" id="day-txns"><div class="empty-state">← Click a day</div></div>
        </div>
      </div>
    </div>

    <div class="page" id="page-transactions">
      <div class="page-header">
        <div class="page-title">Transactions</div>
        <div class="page-sub">Last 30 days</div>
      </div>
      <div class="panel">
        <div class="txn-list" id="all-txns"><div class="spinner"></div></div>
      </div>
    </div>

    <div class="page" id="page-accounts">
      <div class="page-header">
        <div class="page-title">Connected Banks</div>
        <div class="page-sub">Manage your Teller bank connections</div>
      </div>
      <div class="accounts-grid" id="accounts-grid"><div class="spinner"></div></div>
    </div>
  </div>
</div>

<script>
const API_BASE = 'https://spendlog-backend-production.up.railway.app/api/v1';
const ADMIN_KEY = 'SL-ADMIN-2026';
const TELLER_APP_ID = 'app_pqf12skur572k1h1sm000';
const Cal = { year: new Date().getFullYear(), month: new Date().getMonth() + 1, days: {} };

function getDeviceId() {
  let id = localStorage.getItem('sl_device_id');
  if (!id) { id = crypto.randomUUID(); localStorage.setItem('sl_device_id', id); }
  return id;
}

async function apiFetch(path, options = {}) {
  const headers = { 'Content-Type': 'application/json', 'X-Device-ID': getDeviceId(), ...options.headers };
  const res = await fetch(`${API_BASE}${path}`, { ...options, headers });
  if (res.status === 204) return null;
  const data = await res.json();
  if (!res.ok) throw new Error(data.detail || `HTTP ${res.status}`);
  return data;
}

document.getElementById('key-input').addEventListener('keydown', e => { if (e.key==='Enter') tryUnlock(); });

function tryUnlock() {
  const val = document.getElementById('key-input').value.trim();
  const input = document.getElementById('key-input');
  if (val === ADMIN_KEY) {
    localStorage.setItem('sl_admin','1');
    document.getElementById('lock').classList.add('hidden');
    document.getElementById('dash').classList.add('visible');
    initDash();
  } else {
    input.classList.add('error');
    document.getElementById('lock-error').textContent = 'Invalid admin key.';
    setTimeout(() => { input.classList.remove('error'); document.getElementById('lock-error').textContent=''; input.value=''; }, 1500);
  }
}

function lockOut() {
  localStorage.removeItem('sl_admin');
  document.getElementById('lock').classList.remove('hidden');
  document.getElementById('dash').classList.remove('visible');
  document.getElementById('key-input').value='';
}

function initDash() {
  document.getElementById('device-id-display').textContent = getDeviceId().slice(0,20)+'…';
  document.getElementById('overview-date').textContent = new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  loadOverview();
  loadCalendarData();
}

if (localStorage.getItem('sl_admin')==='1') {
  document.getElementById('lock').classList.add('hidden');
  document.getElementById('dash').classList.add('visible');
  initDash();
}

function showPage(el, name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  el.classList.add('active');
  if (name==='transactions') loadAllTxns();
  if (name==='accounts') loadAccounts();
}

async function loadOverview() {
  try {
    const today = new Date().toISOString().slice(0,10);
    const [calData, recentData, accts] = await Promise.all([
      apiFetch(`/transactions/calendar?year=${Cal.year}&month=${Cal.month}`),
      apiFetch('/transactions?limit=15'),
      apiFetch('/teller/accounts').catch(()=>[]),
    ]);
    let monthTotal=0,txnCount=0,todayTotal=0,todayCount=0;
    (calData.days||[]).forEach(d=>{
      monthTotal+=parseFloat(d.total_spent||0); txnCount+=d.transaction_count||0;
      if(d.date===today){todayTotal+=parseFloat(d.total_spent||0);todayCount+=d.transaction_count||0;}
    });
    document.getElementById('stat-month').textContent=fmt(monthTotal);
    document.getElementById('stat-txn-count').textContent=`${txnCount} transaction${txnCount===1?'':'s'}`;
    document.getElementById('stat-today').textContent=fmt(todayTotal);
    document.getElementById('stat-today-count').textContent=`${todayCount} today`;
    document.getElementById('stat-banks').textContent=accts.length||'0';
    const txns=recentData.transactions||[];
    if(txns.length){document.getElementById('stat-last-amt').textContent=fmt(txns[0].amount);document.getElementById('stat-last-name').textContent=txns[0].merchant_name||txns[0].name;}
    document.getElementById('recent-txns').innerHTML=txns.length?txns.map(t=>txnRow(t)).join(''):'<div class="empty-state">No transactions yet</div>';
    renderMiniCal(calData.days||[]);
  } catch(e){console.error(e);}
}

function renderMiniCal(days) {
  const dayMap={};days.forEach(d=>dayMap[d.date]=d);
  const spends=days.map(d=>parseFloat(d.total_spent||0));const maxSpend=Math.max(...spends,1);
  const firstDay=new Date(Cal.year,Cal.month-1,1).getDay();
  const daysInMonth=new Date(Cal.year,Cal.month,0).getDate();
  const todayStr=new Date().toISOString().slice(0,10);
  let html='';
  for(let i=0;i<firstDay;i++)html+='<div class="cal-cell empty"></div>';
  for(let d=1;d<=daysInMonth;d++){
    const ds=`${Cal.year}-${String(Cal.month).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dd=dayMap[ds];let cls='cal-cell';
    if(ds===todayStr)cls+=' today';
    if(dd){const i=parseFloat(dd.total_spent||0)/maxSpend;if(i>0.6)cls+=' spend-high';else if(i>0.25)cls+=' spend-mid';else if(i>0)cls+=' spend-low';}
    html+=`<div class="${cls}"><div class="cal-day">${d}</div></div>`;
  }
  document.getElementById('mini-cal').innerHTML=html;
}

async function loadCalendarData() {
  try {
    const data=await apiFetch(`/transactions/calendar?year=${Cal.year}&month=${Cal.month}`);
    Cal.days={};let total=0;
    (data.days||[]).forEach(d=>{Cal.days[d.date]=d;total+=parseFloat(d.total_spent||0);});
    document.getElementById('full-month-label').textContent=new Date(Cal.year,Cal.month-1,1).toLocaleDateString('en-US',{month:'long',year:'numeric'});
    document.getElementById('full-month-total').textContent=fmt(total);
    renderFullCal();
  } catch(e){}
}

function renderFullCal() {
  const el=document.getElementById('full-cal');
  const spends=Object.values(Cal.days).map(d=>parseFloat(d.total_spent||0));
  const maxSpend=Math.max(...spends,1);
  const firstDay=new Date(Cal.year,Cal.month-1,1).getDay();
  const daysInMonth=new Date(Cal.year,Cal.month,0).getDate();
  const todayStr=new Date().toISOString().slice(0,10);
  let html='';
  for(let i=0;i<firstDay;i++)html+='<div class="cal-cell empty"></div>';
  for(let d=1;d<=daysInMonth;d++){
    const ds=`${Cal.year}-${String(Cal.month).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dd=Cal.days[ds];let cls='cal-cell';
    if(ds===todayStr)cls+=' today';
    if(dd){const i=parseFloat(dd.total_spent||0)/maxSpend;if(i>0.6)cls+=' spend-high';else if(i>0.25)cls+=' spend-mid';else if(i>0)cls+=' spend-low';}
    const amt=dd?`<div class="cal-amt">${fmt(dd.total_spent)}</div>`:'';
    html+=`<div class="${cls}" onclick="showDay('${ds}',this)"><div class="cal-day">${d}</div>${amt}</div>`;
  }
  el.innerHTML=html;
}

function showDay(dateStr,cell) {
  document.querySelectorAll('#full-cal .cal-cell').forEach(c=>c.classList.remove('selected'));
  cell.classList.add('selected');
  const dd=Cal.days[dateStr];
  document.getElementById('day-panel-date').textContent=new Date(dateStr+'T00:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});
  document.getElementById('day-panel-date').style.color='var(--text)';
  document.getElementById('day-panel-total').textContent=dd?fmt(dd.total_spent):'$0.00';
  document.getElementById('day-panel-count').textContent=dd?`${dd.transaction_count} transaction${dd.transaction_count===1?'':'s'}`:'';
  const txns=document.getElementById('day-txns');
  if(!dd?.transactions?.length){txns.innerHTML='<div class="empty-state">No transactions this day</div>';return;}
  txns.innerHTML=dd.transactions.map(t=>txnRow(t)).join('');
}

function calPrev(){Cal.month--;if(Cal.month<1){Cal.month=12;Cal.year--;}loadCalendarData();}
function calNext(){Cal.month++;if(Cal.month>12){Cal.month=1;Cal.year++;}loadCalendarData();}

async function loadAllTxns() {
  const el=document.getElementById('all-txns');el.innerHTML='<div class="spinner"></div>';
  try {
    const end=new Date().toISOString().slice(0,10);
    const start=new Date(Date.now()-30*24*60*60*1000).toISOString().slice(0,10);
    const data=await apiFetch(`/transactions?start_date=${start}&end_date=${end}&limit=200`);
    const txns=data.transactions||[];
    el.innerHTML=txns.length?txns.map(t=>txnRow(t)).join(''):'<div class="empty-state">No transactions in the last 30 days</div>';
  } catch(e){el.innerHTML=`<p style="color:var(--danger);padding:16px;font-size:.8rem">${e.message}</p>`;}
}

async function loadAccounts() {
  const el=document.getElementById('accounts-grid');el.innerHTML='<div class="spinner"></div>';
  try {
    const accounts=await apiFetch('/teller/accounts').catch(()=>[]);
    const iconMap={credit:'💳',depository:'🏦',loan:'📋'};
    el.innerHTML=accounts.map(a=>`<div class="account-card"><div class="account-icon">${iconMap[a.account_type]||'🏦'}</div><div><div class="account-name">${a.institution_name||'Bank Account'}</div><div class="account-meta">${a.account_subtype||a.account_type||'Account'}${a.mask?` · ••••${a.mask}`:''}</div>${a.last_synced_at?`<div class="account-meta">Synced ${fmtDate(a.last_synced_at.slice(0,10))}</div>`:''}</div></div>`).join('')+
    `<div class="connect-card" onclick="connectBank()"><div style="font-size:28px;background:rgba(240,165,0,0.1);width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center">+</div><div class="connect-card-title">Connect a Bank</div><div class="connect-card-sub">Link via Teller — read-only, bank-grade security</div></div>`;
  } catch(e){el.innerHTML=`<p style="color:var(--danger)">${e.message}</p>`;}
}

async function connectBank() {
  try {
    if(!window.TellerConnect) await new Promise((res,rej)=>{const s=document.createElement('script');s.src='https://cdn.teller.io/connect/connect.js';s.onload=res;s.onerror=rej;document.head.appendChild(s);});
    TellerConnect.setup({
      applicationId:TELLER_APP_ID,environment:'sandbox',
      onSuccess:async(e)=>{await apiFetch('/teller/enroll',{method:'POST',body:JSON.stringify({access_token:e.accessToken,enrollment_id:e.id,institution_name:e.institution?.name})});loadAccounts();loadOverview();},
      onExit:()=>{},onFailure:()=>alert('Connection failed'),
    }).open();
  } catch(e){alert('Failed: '+e.message);}
}

function txnRow(t) {
  const badge=t.is_apple_pay?'<span class="badge badge-apple"> Pay</span>':t.pending?'<span class="badge badge-pending">Pending</span>':'';
  return `<div class="txn-row"><div class="txn-icon" style="background:${catBg(t.category)}">${catEmoji(t.category)}</div><div class="txn-info"><div class="txn-name">${t.merchant_name||t.name}${badge}</div><div class="txn-date">${fmtDate(t.transaction_date)} · ${t.category||'Uncategorized'}</div></div><div class="txn-amt">${fmt(t.amount)}</div></div>`;
}

function fmt(a){return new Intl.NumberFormat('en-US',{style:'currency',currency:'USD'}).format(parseFloat(a)||0);}
function fmtDate(d){const t=new Date().toISOString().slice(0,10);const y=new Date(Date.now()-86400000).toISOString().slice(0,10);if(d===t)return'Today';if(d===y)return'Yesterday';return new Date(d+'T00:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric'});}
function catEmoji(c){if(!c)return'💳';const l=c.toLowerCase();if(l.includes('food')||l.includes('dining'))return'🍔';if(l.includes('travel'))return'✈️';if(l.includes('shop'))return'🛍️';if(l.includes('health'))return'💊';if(l.includes('entertain'))return'🎬';if(l.includes('grocery'))return'🛒';if(l.includes('coffee'))return'☕';if(l.includes('gas'))return'⛽';if(l.includes('transfer'))return'↔️';return'💳';}
function catBg(c){if(!c)return'rgba(144,144,176,0.12)';const l=c.toLowerCase();if(l.includes('food')||l.includes('dining'))return'rgba(249,115,22,0.15)';if(l.includes('travel'))return'rgba(59,130,246,0.15)';if(l.includes('shop'))return'rgba(168,85,247,0.15)';if(l.includes('health'))return'rgba(239,68,68,0.15)';return'rgba(240,165,0,0.1)';}
</script>

<!-- ── NATIVE APP LAYER (mirrors pnfchat exactly) ──────────────────────────
     • iOS standalone detection  → safe-area body class
     • Inline Service Worker     → blob URL, no /sw.js file needed
     • Inline Web Manifest       → blob URL, no manifest.json file needed
     • Install prompt banner     → Android native prompt + iOS share hint
──────────────────────────────────────────────────────────────────────── -->
<script>
// 1. iOS standalone detection
(function() {
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) ||
                (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
  const isStandalone = window.navigator.standalone === true ||
                       window.matchMedia('(display-mode: standalone)').matches;
  if (isStandalone) document.body.classList.add('ios-standalone');
})();

// 2. Manifest + apple-touch-icon (no external files needed)
(function() {
  const iconSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192"><rect width="192" height="192" rx="40" fill="#0A0A0F"/><rect x="24" y="60" width="144" height="96" rx="16" fill="none" stroke="#F0A500" stroke-width="12"/><path d="M24 90h144" stroke="#F0A500" stroke-width="10"/><circle cx="52" cy="126" r="10" fill="#F0A500"/><circle cx="84" cy="126" r="10" fill="#F0A500"/></svg>`;
  const icon = 'data:image/svg+xml,' + encodeURIComponent(iconSvg);

  // Apple touch icon
  const a = document.createElement('link');
  a.rel = 'apple-touch-icon'; a.href = icon;
  document.head.appendChild(a);

  // Web manifest
  const manifest = {
    name: 'SpendLog', short_name: 'SpendLog',
    description: 'SpendLog — personal spending dashboard',
    start_url: '/', display: 'standalone',
    background_color: '#0A0A0F', theme_color: '#0A0A0F',
    icons: [
      { src: icon, sizes: '192x192', type: 'image/svg+xml' },
      { src: icon, sizes: '512x512', type: 'image/svg+xml' }
    ]
  };
  const mBlob = new Blob([JSON.stringify(manifest)], { type: 'application/json' });
  const mLink = document.createElement('link');
  mLink.rel = 'manifest'; mLink.href = URL.createObjectURL(mBlob);
  document.head.appendChild(mLink);
})();

// 4. Install prompt banner — Android native + iOS share hint
let _installPrompt = null;

window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  _installPrompt = e;
  if (!localStorage.getItem('sl_install_dismissed'))
    setTimeout(_showInstallBanner, 3000);
});

window.addEventListener('appinstalled', () => {
  _hideInstallBanner();
  _installPrompt = null;
  localStorage.setItem('sl_install_dismissed', '1');
});

function _showInstallBanner() {
  if (document.getElementById('sl-install-banner')) return;
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) ||
                (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
  const msg = isIOS
    ? `<span style="font-size:13px">Tap <b>Share</b> → <b>Add to Home Screen</b> to install SpendLog</span>`
    : `<span style="font-size:13px"><b>Install SpendLog</b> — use it like a native app</span>`;

  const el = document.createElement('div');
  el.id = 'sl-install-banner';
  el.innerHTML = `
    <div style="
      position:fixed;bottom:calc(16px + env(safe-area-inset-bottom));left:12px;right:12px;
      background:linear-gradient(135deg,#18180F,#1F1A08);
      border:1px solid rgba(240,165,0,0.35);border-radius:16px;
      padding:14px 16px;display:flex;align-items:center;gap:12px;
      box-shadow:0 8px 32px rgba(0,0,0,0.6);z-index:9999;
      animation:sl-slideUp 0.35s cubic-bezier(0.34,1.56,0.64,1)
    ">
      <svg width="40" height="40" viewBox="0 0 192 192" style="border-radius:10px;flex-shrink:0"><rect width="192" height="192" rx="40" fill="#0A0A0F"/><rect x="24" y="60" width="144" height="96" rx="16" fill="none" stroke="#F0A500" stroke-width="12"/><path d="M24 90h144" stroke="#F0A500" stroke-width="10"/><circle cx="52" cy="126" r="10" fill="#F0A500"/><circle cx="84" cy="126" r="10" fill="#F0A500"/></svg>
      <div style="flex:1;color:#F0F0FF;line-height:1.4">${msg}</div>
      ${!isIOS ? `<button onclick="installSpendLog()" style="padding:8px 14px;background:#F0A500;border:none;border-radius:10px;color:#000;font-weight:700;font-size:13px;cursor:pointer;flex-shrink:0;white-space:nowrap">Install</button>` : ''}
      <button onclick="_hideInstallBanner(true)" style="background:none;border:none;color:#606080;font-size:20px;cursor:pointer;flex-shrink:0;line-height:1;padding:2px 4px">✕</button>
    </div>`;
  document.body.appendChild(el);
}

function _hideInstallBanner(dismiss) {
  const el = document.getElementById('sl-install-banner');
  if (el) el.remove();
  if (dismiss) localStorage.setItem('sl_install_dismissed', '1');
}

async function installSpendLog() {
  if (!_installPrompt) return;
  _installPrompt.prompt();
  const { outcome } = await _installPrompt.userChoice;
  if (outcome === 'accepted') { _hideInstallBanner(true); _installPrompt = null; }
}

// iOS: show share hint in Safari (not in standalone)
window.addEventListener('load', () => {
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) ||
                (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
  const isStandalone = window.navigator.standalone === true ||
                       window.matchMedia('(display-mode: standalone)').matches;
  if (isIOS && !isStandalone && !localStorage.getItem('sl_install_dismissed'))
    setTimeout(_showInstallBanner, 4000);
});
</script>
</body>
</html>
