{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/install", "destination": "/install.html" },
    { "source": "/((?!sw.js|manifest.json|icon-192.png|icon-512.png|install.html).*)", "destination": "/index.html" }
  ]
}
