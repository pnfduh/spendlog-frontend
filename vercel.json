{
  "version": 2,
  "routes": [
    { "src": "/apple-touch-icon.png", "headers": { "Cache-Control": "public, max-age=86400" }, "dest": "/apple-touch-icon.png" },
    { "src": "/apple-touch-icon-precomposed.png", "dest": "/apple-touch-icon.png" },
    { "src": "/icon-192.png", "headers": { "Cache-Control": "public, max-age=86400" }, "dest": "/icon-192.png" },
    { "src": "/icon-512.png", "headers": { "Cache-Control": "public, max-age=86400" }, "dest": "/icon-512.png" },
    { "src": "/manifest.json", "headers": { "Content-Type": "application/manifest+json", "Cache-Control": "no-cache" }, "dest": "/manifest.json" },
    { "src": "/sw.js", "headers": { "Cache-Control": "no-cache", "Service-Worker-Allowed": "/" }, "dest": "/sw.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
