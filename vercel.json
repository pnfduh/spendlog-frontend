@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap');

:root {
  --bg-0: #07070F;
  --bg-1: #0D0D1A;
  --bg-2: #141424;
  --bg-3: #1C1C30;
  --accent: #F0A500;
  --accent-dim: rgba(240,165,0,0.1);
  --accent-glow: rgba(240,165,0,0.25);
  --text-0: #F4F4FF;
  --text-1: #9090B0;
  --text-2: #50506A;
  --success: #00D4A0;
  --danger: #FF4D6D;
  --warning: #F0A500;
  --border: rgba(255,255,255,0.06);
  --border-accent: rgba(240,165,0,0.2);
  --font-display: 'Playfair Display', Georgia, serif;
  --font-ui: 'Outfit', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', 'Courier New', monospace;
  --radius-sm: 8px;
  --radius-md: 14px;
  --radius-lg: 20px;
  --radius-xl: 28px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: var(--font-ui);
  background: var(--bg-0);
  color: var(--text-0);
  line-height: 1.5;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
img, svg { display: block; max-width: 100%; }
button { cursor: pointer; border: none; background: none; font-family: inherit; }
a { color: inherit; text-decoration: none; }
input { font-family: inherit; }

/* ── MODE SWITCHING ── */
#landing { display: block; }
#app     { display: none; }
html.app-mode #landing { display: none; }
html.app-mode #app     { display: flex; flex-direction: column; min-height: 100dvh; }

/* ═══════════════════════════════════════════
   LANDING
═══════════════════════════════════════════ */
.l-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 28px;
  background: rgba(7,7,15,0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
.l-nav-logo {
  display: flex; align-items: center; gap: 10px;
  font-family: var(--font-display); font-size: 1.25rem; font-weight: 700;
}
.l-nav-logo .logo-icon {
  width: 32px; height: 32px; background: var(--accent); border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
}
.l-nav-logo .logo-icon svg { width: 18px; height: 18px; }
.l-nav-install {
  padding: 9px 20px; background: var(--accent); color: #000;
  font-weight: 700; font-size: 0.875rem; border-radius: 100px;
  transition: transform 0.15s, box-shadow 0.15s;
}
.l-nav-install:hover { transform: translateY(-1px); box-shadow: 0 8px 24px var(--accent-glow); }

.l-hero {
  min-height: 100dvh; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; padding: 120px 24px 80px;
  position: relative; overflow: hidden;
}
.l-hero::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(240,165,0,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(240,165,0,0.03) 1px, transparent 1px);
  background-size: 48px 48px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
}
.l-hero-orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; }
.l-hero-orb-1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(240,165,0,0.08) 0%, transparent 70%);
  top: -100px; left: 50%; transform: translateX(-50%);
}
.l-hero-orb-2 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(100,80,255,0.06) 0%, transparent 70%);
  bottom: 80px; right: -50px;
}
.l-hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; background: var(--accent-dim);
  border: 1px solid var(--border-accent); border-radius: 100px;
  font-size: 0.8rem; font-weight: 600; color: var(--accent);
  margin-bottom: 28px; animation: fadeSlideDown 0.6s ease both;
}
.l-hero-badge span { display: inline-block; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
.l-hero h1 {
  font-family: var(--font-display);
  font-size: clamp(2.6rem, 8vw, 5.5rem);
  font-weight: 900; line-height: 1.06; letter-spacing: -0.03em;
  margin-bottom: 24px; animation: fadeSlideDown 0.6s 0.1s ease both;
}
.l-hero h1 em {
  font-style: italic;
  background: linear-gradient(135deg, var(--accent) 0%, #FFD060 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.l-hero p {
  max-width: 520px; margin: 0 auto 40px;
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  color: var(--text-1); line-height: 1.7;
  animation: fadeSlideDown 0.6s 0.2s ease both;
}
.l-hero-cta {
  display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;
  animation: fadeSlideDown 0.6s 0.3s ease both;
}
.btn-primary {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 32px; background: var(--accent); color: #000;
  font-weight: 700; font-size: 1rem; border-radius: 100px;
  box-shadow: 0 0 40px var(--accent-glow);
  transition: transform 0.15s, box-shadow 0.15s;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 40px var(--accent-glow); }
.btn-secondary {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 32px; background: var(--bg-2); color: var(--text-0);
  font-weight: 600; font-size: 1rem; border-radius: 100px;
  border: 1px solid var(--border); transition: border-color 0.15s, background 0.15s;
}
.btn-secondary:hover { border-color: var(--border-accent); background: var(--bg-3); }

.l-preview { margin-top: 72px; animation: fadeSlideDown 0.8s 0.4s ease both; display: flex; justify-content: center; }
.l-preview-phone {
  width: 280px; background: var(--bg-1); border: 1px solid var(--border);
  border-radius: 40px; padding: 16px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.5), 0 0 60px rgba(240,165,0,0.08); overflow: hidden;
}
.l-preview-notch { width: 80px; height: 24px; background: var(--bg-0); border-radius: 12px; margin: 0 auto 16px; }
.l-preview-screen { display: flex; flex-direction: column; gap: 10px; }
.l-preview-header { display: flex; justify-content: space-between; align-items: flex-end; padding: 0 4px; }
.l-preview-month { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; }
.l-preview-total { font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent); }
.l-preview-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; }
.l-preview-cell {
  aspect-ratio: 1; border-radius: 6px; background: var(--bg-2);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.55rem; color: var(--text-2);
}
.l-preview-cell.has-spend { background: rgba(240,165,0,0.2); color: var(--accent); font-weight: 600; }
.l-preview-cell.high-spend { background: rgba(240,165,0,0.5); color: #000; font-weight: 700; }
.l-preview-cell.today { outline: 1.5px solid var(--accent); }
.l-preview-cell.empty { background: transparent; }
.l-preview-cell.selected { outline: 2px solid var(--accent); background: rgba(240,165,0,0.3); }
.l-preview-txn { display: flex; align-items: center; gap: 8px; padding: 8px; background: var(--bg-2); border-radius: 10px; }
.l-preview-txn-icon { width: 28px; height: 28px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
.l-preview-txn-info { flex: 1; min-width: 0; }
.l-preview-txn-name { font-size: 0.65rem; font-weight: 600; }
.l-preview-txn-cat { font-size: 0.55rem; color: var(--text-2); margin-top: 1px; }
.l-preview-txn-amt { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; }

.l-section { padding: 100px 24px; max-width: 1100px; margin: 0 auto; }
.l-section-label { text-align: center; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; }
.l-section-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 900; line-height: 1.1; letter-spacing: -0.03em; text-align: center; margin-bottom: 64px; }

.l-features { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; }
.l-feature {
  background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 32px; transition: border-color 0.2s, transform 0.2s; position: relative; overflow: hidden;
}
.l-feature:hover { border-color: var(--border-accent); transform: translateY(-2px); }
.l-feature-icon { width: 48px; height: 48px; background: var(--accent-dim); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; font-size: 22px; }
.l-feature h3 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 10px; }
.l-feature p { font-size: 0.95rem; color: var(--text-1); line-height: 1.65; }

.l-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; }
.l-step { display: flex; gap: 20px; align-items: flex-start; }
.l-step-num { font-family: var(--font-display); font-size: 3rem; font-weight: 900; line-height: 1; color: var(--accent); opacity: 0.25; flex-shrink: 0; width: 52px; }
.l-step-content h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 8px; }
.l-step-content p { font-size: 0.9rem; color: var(--text-1); line-height: 1.6; }

.l-install-section { padding: 80px 24px 120px; text-align: center; }
.l-install-card {
  max-width: 600px; margin: 0 auto; background: var(--bg-1);
  border: 1px solid var(--border-accent); border-radius: var(--radius-xl);
  padding: 56px 40px; box-shadow: 0 0 32px rgba(240,165,0,0.15);
}
.l-install-card h2 { font-family: var(--font-display); font-size: clamp(1.8rem,4vw,2.6rem); font-weight: 900; line-height: 1.1; margin-bottom: 16px; }
.l-install-card p { color: var(--text-1); margin-bottom: 36px; font-size: 1rem; line-height: 1.7; }
#installBtn {
  display: inline-flex; align-items: center; gap: 12px;
  padding: 18px 40px; background: var(--accent); color: #000;
  font-weight: 700; font-size: 1.05rem; border-radius: 100px;
  box-shadow: 0 0 50px var(--accent-glow); transition: transform 0.15s, box-shadow 0.15s; margin-bottom: 16px;
}
#installBtn:hover { transform: translateY(-2px); box-shadow: 0 12px 50px var(--accent-glow); }

.l-footer { text-align: center; padding: 32px 24px; border-top: 1px solid var(--border); font-size: 0.85rem; color: var(--text-2); }

#ios-banner {
  display: none; position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--bg-2); border-top: 1px solid var(--border-accent);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 20px 20px 36px; z-index: 200;
  transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow: 0 -8px 40px rgba(0,0,0,0.5);
}
#ios-banner.show { transform: translateY(0); }
.ios-banner-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.ios-banner-title { font-weight: 700; font-size: 1rem; }
.ios-banner-close { width: 28px; height: 28px; background: var(--bg-3); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--text-1); font-size: 14px; }
.ios-steps { display: flex; flex-direction: column; gap: 12px; }
.ios-step { display: flex; align-items: center; gap: 14px; padding: 12px 14px; background: var(--bg-3); border-radius: var(--radius-sm); }
.ios-step-icon { font-size: 20px; flex-shrink: 0; }
.ios-step-text { font-size: 0.875rem; color: var(--text-1); line-height: 1.4; }
.ios-step-text strong { color: var(--text-0); font-weight: 600; }

/* ═══════════════════════════════════════════
   APP
═══════════════════════════════════════════ */
#app { height: 100dvh; flex-direction: column; background: var(--bg-0); overflow: hidden; }
.view { display: none; flex: 1; flex-direction: column; overflow: hidden; }
.view.active { display: flex; }

.app-tabs {
  display: flex; background: var(--bg-1); border-top: 1px solid var(--border);
  padding-bottom: env(safe-area-inset-bottom, 12px); flex-shrink: 0;
}
.app-tab {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 10px 4px 4px; gap: 4px; color: var(--text-2);
  font-size: 0.65rem; font-weight: 600; letter-spacing: 0.04em; transition: color 0.15s;
}
.app-tab svg { width: 22px; height: 22px; stroke-width: 1.8; }
.app-tab.active { color: var(--accent); }
.app-tab.active svg { stroke: var(--accent); }

.app-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px 12px;
  padding-top: calc(env(safe-area-inset-top, 0px) + 16px);
  flex-shrink: 0;
}
.app-header-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; letter-spacing: -0.02em; }
.app-header-sub { font-size: 0.75rem; color: var(--text-2); margin-top: 2px; }
.app-avatar {
  width: 36px; height: 36px; border-radius: 50%; background: var(--accent); color: #000;
  display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.875rem;
}

/* Calendar */
#view-calendar { flex-direction: column; overflow: hidden; }
.calendar-scroll { flex: 1; overflow-y: auto; padding: 0 16px 16px; }
.month-nav { display: flex; align-items: center; justify-content: space-between; padding: 8px 0 16px; }
.month-nav-label { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; }
.month-nav-arrows { display: flex; gap: 6px; }
.month-nav-btn {
  width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--bg-2);
  color: var(--text-1); display: flex; align-items: center; justify-content: center;
  font-size: 16px; transition: background 0.15s, color 0.15s;
}
.month-nav-btn:hover { background: var(--bg-3); color: var(--text-0); }
.month-total-card {
  background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-md);
  padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;
}
.month-total-label { font-size: 0.75rem; color: var(--text-1); margin-bottom: 4px; }
.month-total-amount { font-family: var(--font-mono); font-size: 1.8rem; font-weight: 700; color: var(--accent); }
.month-total-count { font-size: 0.8rem; color: var(--text-2); margin-top: 2px; }
.cal-weekdays { display: grid; grid-template-columns: repeat(7,1fr); gap: 2px; margin-bottom: 4px; }
.cal-weekday { text-align: center; font-size: 0.65rem; font-weight: 700; color: var(--text-2); letter-spacing: 0.05em; padding: 4px 0; }
.cal-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; }
.cal-cell {
  aspect-ratio: 1; border-radius: 8px; background: var(--bg-2);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  cursor: pointer; transition: transform 0.1s; padding: 2px; position: relative;
}
.cal-cell:hover { transform: scale(1.05); }
.cal-cell.empty { background: transparent; cursor: default; pointer-events: none; }
.cal-cell.today { box-shadow: 0 0 0 1.5px var(--accent); }
.cal-cell.selected { background: rgba(240,165,0,0.25); }
.cal-cell.spend-low  { background: rgba(240,165,0,0.15); }
.cal-cell.spend-mid  { background: rgba(240,165,0,0.35); }
.cal-cell.spend-high { background: rgba(240,165,0,0.6); }
.cal-cell-day { font-size: 0.7rem; font-weight: 500; color: var(--text-1); line-height: 1; }
.cal-cell.spend-low .cal-cell-day, .cal-cell.spend-mid .cal-cell-day { color: var(--accent); font-weight: 600; }
.cal-cell.spend-high .cal-cell-day { color: #000; font-weight: 700; }
.cal-cell.today .cal-cell-day { color: var(--accent); font-weight: 700; }
.cal-cell-dots { display: flex; gap: 2px; margin-top: 2px; }
.cal-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--accent); opacity: 0.6; }
.cal-cell.spend-high .cal-dot { background: #000; }

.day-detail {
  display: none; flex-direction: column; background: var(--bg-1);
  border-top: 1px solid var(--border); max-height: 45dvh; overflow-y: auto; flex-shrink: 0;
}
.day-detail.show { display: flex; }
.day-detail-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 16px 10px; flex-shrink: 0; position: sticky; top: 0;
  background: var(--bg-1); z-index: 1; border-bottom: 1px solid var(--border);
}
.day-detail-date { font-weight: 700; font-size: 0.9rem; }
.day-detail-total { font-family: var(--font-mono); font-weight: 700; color: var(--accent); }
.day-detail-close { width: 24px; height: 24px; background: var(--bg-3); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--text-1); font-size: 12px; }
.day-detail-list { padding: 8px 12px 16px; }

/* Transactions */
.txn-item {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 14px; background: var(--bg-2); border-radius: var(--radius-sm);
  margin-bottom: 4px; cursor: pointer; transition: background 0.15s;
}
.txn-item:hover { background: var(--bg-3); }
.txn-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.txn-body { flex: 1; min-width: 0; }
.txn-name { font-size: 0.875rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.txn-meta { font-size: 0.72rem; color: var(--text-2); margin-top: 2px; }
.txn-badges { display: inline-flex; gap: 4px; margin-left: 6px; }
.txn-badge { font-size: 0.6rem; font-weight: 700; padding: 1px 5px; border-radius: 4px; }
.txn-badge.apple { background: rgba(255,255,255,0.08); color: var(--text-1); }
.txn-badge.pending { background: rgba(240,165,0,0.15); color: var(--accent); }
.txn-amount { font-family: var(--font-mono); font-size: 0.9rem; font-weight: 700; white-space: nowrap; }
.txn-amount.pending { color: var(--text-1); }

/* Activity */
#view-activity { flex-direction: column; }
.activity-scroll { flex: 1; overflow-y: auto; padding: 0 16px 16px; }
.txn-group-header {
  display: flex; justify-content: space-between;
  font-size: 0.72rem; font-weight: 700; color: var(--text-2);
  letter-spacing: 0.05em; text-transform: uppercase;
  padding: 12px 2px 6px; position: sticky; top: 0; background: var(--bg-0); z-index: 1;
}
.txn-group-total { color: var(--text-1); font-family: var(--font-mono); }

/* Accounts */
#view-accounts { flex-direction: column; }
.accounts-scroll { flex: 1; overflow-y: auto; padding: 0 16px 16px; }
.account-card {
  background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-md);
  padding: 16px; display: flex; align-items: center; gap: 14px; margin-bottom: 10px;
}
.account-icon { width: 46px; height: 46px; border-radius: 12px; background: var(--accent-dim); display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
.account-body { flex: 1; min-width: 0; }
.account-name { font-weight: 700; font-size: 0.95rem; margin-bottom: 3px; }
.account-sub { font-size: 0.8rem; color: var(--text-1); }
.account-mask { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-2); }
.connect-btn {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  width: 100%; padding: 15px; background: var(--accent-dim); color: var(--accent);
  border: 1px dashed var(--border-accent); border-radius: var(--radius-md);
  font-weight: 700; font-size: 0.95rem; transition: background 0.15s; margin-top: 4px;
}
.connect-btn:hover { background: rgba(240,165,0,0.15); }
.security-note {
  display: flex; gap: 12px; align-items: flex-start; padding: 14px;
  background: rgba(0,212,160,0.06); border: 1px solid rgba(0,212,160,0.15);
  border-radius: var(--radius-sm); margin-top: 14px;
}
.security-note-icon { font-size: 18px; flex-shrink: 0; }
.security-note p { font-size: 0.78rem; color: var(--text-1); line-height: 1.5; }

/* Settings */
#view-settings { flex-direction: column; }
.settings-scroll { flex: 1; overflow-y: auto; padding: 0 16px 16px; }
.settings-profile {
  display: flex; align-items: center; gap: 14px; padding: 20px;
  background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-md); margin-bottom: 20px;
}
.settings-avatar {
  width: 54px; height: 54px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent) 0%, #FF8C00 100%);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; color: #000; flex-shrink: 0;
}
.settings-name { font-weight: 700; font-size: 1rem; }
.settings-email { font-size: 0.82rem; color: var(--text-1); margin-top: 2px; }
.settings-section-title { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-2); margin: 20px 0 8px 4px; }
.settings-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 16px; background: var(--bg-1); border-bottom: 1px solid var(--border);
}
.settings-row:first-of-type { border-radius: var(--radius-sm) var(--radius-sm) 0 0; }
.settings-row:last-of-type { border-bottom: none; border-radius: 0 0 var(--radius-sm) var(--radius-sm); }
.settings-row-label { font-size: 0.9rem; font-weight: 500; }
.settings-row-value { font-size: 0.85rem; color: var(--text-1); }

/* Modal */
.modal-overlay {
  display: none; position: fixed; inset: 0; z-index: 300;
  background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); align-items: flex-end;
}
.modal-overlay.show { display: flex; }
.modal-sheet {
  width: 100%; background: var(--bg-1);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 8px 20px calc(env(safe-area-inset-bottom, 16px) + 16px);
  animation: slideUp 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.modal-handle { width: 36px; height: 4px; background: var(--bg-3); border-radius: 2px; margin: 0 auto 20px; }
.modal-hero { text-align: center; padding: 8px 0 24px; border-bottom: 1px solid var(--border); margin-bottom: 16px; }
.modal-icon { width: 64px; height: 64px; border-radius: 18px; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; font-size: 28px; }
.modal-amount { font-family: var(--font-mono); font-size: 2.4rem; font-weight: 700; }
.modal-merchant { font-size: 1rem; color: var(--text-1); margin-top: 4px; }
.modal-detail-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); font-size: 0.875rem; }
.modal-detail-row:last-child { border-bottom: none; }
.modal-detail-label { color: var(--text-1); }
.modal-detail-value { font-weight: 600; text-align: right; }

/* Utility */
.spinner { width: 36px; height: 36px; border: 3px solid var(--bg-3); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 40px auto; }
.empty-state { text-align: center; padding: 48px 24px; color: var(--text-2); font-size: 0.9rem; }
.empty-state svg { margin: 0 auto 16px; opacity: 0.3; }
.empty-state p { margin-top: 8px; }
.hidden { display: none !important; }

@keyframes fadeSlideDown { from { opacity: 0; transform: translateY(-16px); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideUp { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
@keyframes spin { to { transform: rotate(360deg); } }
